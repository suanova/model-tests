# API key — required for all tests.
# Copy this file to .env and fill in your key:
#   cp .env.example .env
# Then edit .env and replace the value below.
API_KEY=your_api_key_here

# Optional: override the gateway base URL (defaults to https://cuberouter.cn)
# BASE_URL=https://cuberouter.cn

# ── Gateway B config (for compare_gateways.sh) ───────────────────────
# Required when running compare_gateways.sh. Can also be passed via
# CLI flags (--b-key, --b-url) which override these values.
# API_KEY_B=your_second_api_key_here
# BASE_URL_B=https://other-gateway.example.com
